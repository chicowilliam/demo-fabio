{
  "name": "supermercado-guia-compras",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api:dev": "dotenv -e api/.env -- tsx api/src/index.ts",
    "api:build": "dotenv -e api/.env -- prisma generate --schema api/prisma/schema.prisma && tsc -p api/tsconfig.json",
    "api:start": "dotenv -e api/.env -- node api/dist/src/index.js",
    "api:db:generate": "dotenv -e api/.env -- prisma generate --schema api/prisma/schema.prisma",
    "api:db:migrate:dev": "dotenv -e api/.env -- prisma migrate dev --schema api/prisma/schema.prisma",
    "api:db:seed": "dotenv -e api/.env -- tsx api/prisma/seed.ts",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@casl/ability": "^6.8.0",
    "@prisma/adapter-pg": "^6.16.0",
    "@prisma/client": "^6.16.0",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.1.1",
    "@tanstack/react-query": "^5.45.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "lucide-react": "^0.263.1",
    "p-queue": "^7.4.1",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^7.4.4",
    "postcss": "^8.4.49",
    "prisma": "^6.16.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
